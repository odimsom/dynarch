{
  "name": "dynarch",
  "version": "1.0.0",
  "description": "Metadata-architecture, plug and play",
  "private": true,
  "packageManager": "pnpm@10.33.4",
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "dev": "pnpm --filter './apps/*' run dev",
    "build": "pnpm --filter './packages/*' run build && pnpm --filter './apps/*' run build",
    "start": "pnpm --filter './apps/*' run start",
    "test": "pnpm --recursive run test",
    "lint": "pnpm --recursive run lint"
  },
  "authors": [
    "Alexander Matos",
    "Francisco Daniel Castro Borrome"
  ],
  "license": "Proprietary",
  "licenseDetails": {
    "type": "Proprietary / Revenue Share",
    "summary": "Internal use is permitted at no cost. Commercial use or revenue-generating activities require a commercial license.",
    "usage_policy": {
      "internal_use_allowed": true,
      "commercial_use_allowed": false,
      "requires_commercial_license": true,
      "license_url": "https://dynarch.net"
    },
    "software_name": "dynarch"
  }
}
